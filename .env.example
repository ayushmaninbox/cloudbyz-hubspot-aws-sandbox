# HubSpot API Credentials
# Create a Private App in HubSpot and copy the Access Token (starts with pat-...)
HUBSPOT_TOKEN=your_private_app_access_token_here

# The HubSpot Content Group ID for your blog pages (numeric string)
HUBSPOT_BLOG_ID=your_hubspot_blog_id_here

# [Optional] AWS API Gateway Endpoint URL
# Set this to route your client-side AWS AJAX portal directly to your live Lambda endpoint.
# If left empty or commented out, the AWS AJAX portal will fallback to the local simulation API.
# AWS_API_URL=https://your-api-id.execute-api.your-region.amazonaws.com/api/blogs
